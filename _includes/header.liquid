<header class="w-full {% if site.navbar_fixed %}sticky top-0{%- endif -%} z-50 bg-white/90 dark:bg-stone-900/90 backdrop-blur-md border-b border-stone-200/80 dark:border-stone-800">
  <nav class="max-w-[930px] mx-auto px-6 h-24 flex items-center justify-between" role="navigation">
    
    <a class="flex items-center" href="{{ site.baseurl | prepend: site.url }}/">
      <img src="{{ '/assets/img/logo.png' | relative_url }}" alt="Logo" class="h-16 w-auto object-contain block">
    </a>

    <div class="flex items-center">
      <ul class="flex items-center gap-6 m-0 p-0 list-none text-stone-700 dark:text-stone-300 font-medium">
        
        {%- for page in site.pages -%}
          {% if page.permalink == '/' %}
            {% assign about_title = page.title %}
          {% endif %}
        {% endfor %}

        <li class="inline-block">
          <a class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors {% if page.permalink == '/' %}text-purple-600 dark:text-purple-400 font-semibold{% endif %}" href="{{ '/' | relative_url }}">
            {{ about_title }}
          </a>
        </li>

        {%- assign sorted_pages = site.pages | sort: "nav_order" -%}
        {%- for p in sorted_pages -%}
          {%- if p.nav and p.autogen == nil -%}
            <li class="inline-block">
              <a class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors {% if page.title == p.title %}text-purple-600 dark:text-purple-400 font-semibold{% endif %}" href="{{ p.url | relative_url }}">
                {{ p.title }}
              </a>
            </li>
          {%- endif -%}
        {%- endfor %}

        {%- if site.search_enabled -%}
        <li class="inline-block">
          <button id="search-toggle" class="flex items-center gap-1 hover:text-purple-600 dark:hover:text-purple-400 transition-colors bg-transparent border-none cursor-pointer p-0 font-medium text-stone-700 dark:text-stone-300" title="Search" onclick="openSearchModal()">
            <span>壓下 ⌘ k <i class="ti ti-search"></i></span>
          </button>
        </li>
        {%- endif -%}

        {%- if site.enable_darkmode -%}
        <li class="inline-block flex items-center">
          <button id="light-toggle" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors bg-transparent border-none cursor-pointer p-0 text-stone-700 dark:text-stone-300" title="Change theme">
            <i class="fa-solid fa-moon dark:hidden"></i>
            <i class="fa-solid fa-sun hidden dark:block"></i>
          </button>
        </li>
        {%- endif -%}

      </ul>
    </div>
  </nav>

  {% if site.enable_progressbar %}
    <progress id="progress" value="0" class="w-full h-1 fixed top-0 left-0 z-50 accent-purple-600 bg-transparent appearance-none">
      <div class="w-full bg-transparent">
        <span class="bg-purple-600 h-full block"></span>
      </div>
    </progress>
  {% endif %}
</header>
